# =============================================================================
# OID - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# NEVER commit the .env file to git (it's already in .gitignore)
# =============================================================================

# -- VPN Client 1 Credentials -----------------------------------------------
# Leave empty for certificate-based authentication (no username/password)
CLIENT1_USER=
CLIENT1_PASS=

# -- VPN Client 2 Credentials -----------------------------------------------
CLIENT2_USER=
CLIENT2_PASS=

# -- Global Settings --------------------------------------------------------
# URL to check VPN tunnel health (verified via SOCKS5 proxy)
HEALTH_CHECK_URL=http://ifconfig.me

# Container timezone
TZ=UTC
