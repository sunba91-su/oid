client
dev tun
proto udp

remote YOUR_VPN_SERVER_IP 1194

resolv-retry infinite
nobind
persist-key
persist-tun

cipher AES-256-GCM
auth SHA256

verb 3

# For username/password authentication:
# auth-user-pass

# If your VPN provider uses a specific CA certificate, include it:
# <ca>
# -----BEGIN CERTIFICATE-----
# ...your CA certificate here...
# -----END CERTIFICATE-----
# </ca>

# If your VPN provider uses a client certificate, include it:
# <cert>
# -----BEGIN CERTIFICATE-----
# ...your client certificate here...
# -----END CERTIFICATE-----
# </cert>

# If your VPN provider uses a client key, include it:
# <key>
# -----BEGIN PRIVATE KEY-----
# ...your client private key here...
# -----END PRIVATE KEY-----
# </key>
